#!/usr/bin/env zsh

# Performance profiling (uncomment to debug slow startup)
# zmodload zsh/zprof

#
# Path Setup (Native Zsh Deduplication)
#
typeset -U path PATH
path=(
  /usr/local/share/npm/bin
  $HOME/Library/pnpm
  /opt/homebrew/bin
  /opt/homebrew/sbin
  $HOME/.bin
  $HOME/.cargo/bin
  /usr/local/bin
  /usr/bin
  /bin
  /usr/sbin
  /sbin
  $path
)

#
# 1. Environment & Options (Pre-Plugin)
#
[[ -f "$HOME/.config/zsh/exports.zsh" ]] && source "$HOME/.config/zsh/exports.zsh"
[[ -f "$HOME/.config/zsh/options.zsh" ]] && source "$HOME/.config/zsh/options.zsh"

#
# 2. Initialize Completion
#
autoload -Uz compinit
# Check if dump file is older than 24h, if so regenerate.
zcompdump="${ZDOTDIR:-$HOME}/.zcompdump"
if [[ ! -f "$zcompdump" || -n "$zcompdump"(#qN.mh+24) ]]; then
  compinit -d "$zcompdump"
else
  compinit -C -d "$zcompdump"
fi
unset zcompdump

#
# 3. Antidote Plugin Manager
#
# Determine Homebrew prefix
if command -v brew &>/dev/null; then
  BREW_PREFIX="$(brew --prefix)"
elif [[ -d /opt/homebrew ]]; then
  BREW_PREFIX="/opt/homebrew"
else
  BREW_PREFIX="/usr/local"
fi

# Load Antidote
if [[ -f "$BREW_PREFIX/opt/antidote/share/antidote/antidote.zsh" && -f "${ZDOTDIR:-$HOME}/.zsh_plugins.txt" ]]; then
  source "$BREW_PREFIX/opt/antidote/share/antidote/antidote.zsh"
  # Initialize plugins statically for speed
  antidote load "${ZDOTDIR:-$HOME}/.zsh_plugins.txt"
fi
unset BREW_PREFIX

#
# 4. Functions, Aliases, Bindings (Post-Plugin)
#
[[ -f "$HOME/.config/zsh/completion.zsh" ]] && source "$HOME/.config/zsh/completion.zsh"
[[ -f "$HOME/.config/zsh/functions.zsh" ]] && source "$HOME/.config/zsh/functions.zsh"
[[ -f "$HOME/.config/zsh/aliases.zsh" ]] && source "$HOME/.config/zsh/aliases.zsh"
[[ -f "$HOME/.config/zsh/bindings.zsh" ]] && source "$HOME/.config/zsh/bindings.zsh"

#
# Tool Initialization
#

# FNM (Fast Node Manager)
if command -v fnm &>/dev/null; then
  eval "$(fnm env --use-on-cd)"
fi

# Zoxide (Smart cd)
if command -v zoxide &>/dev/null; then
  eval "$(zoxide init zsh --cmd cd)"
fi

# FZF
if command -v fzf &>/dev/null; then
  # fzf restores the read-only zle option on reload in some zsh contexts; keep
  # `source ~/.zshrc` quiet while still installing the widgets/keybindings.
  eval "$(fzf --zsh)" 2>/dev/null
  
  if command -v fd &>/dev/null; then
    export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
  fi
  
  # Catppuccin Mocha theme for fzf
  export FZF_DEFAULT_OPTS=" \
    --color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 \
    --color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc \
    --color=marker:#f5e0dc,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8"
fi

# GitHub CLI Completion
if command -v gh &>/dev/null; then
  eval "$(gh completion -s zsh)"
fi

# Atuin (Better shell history)
if command -v atuin &>/dev/null; then
  eval "$(atuin init zsh)"
fi

#
# Theme (Oh My Posh)
#
if command -v oh-my-posh &>/dev/null && command -v brew &>/dev/null; then
  OMP_CONFIG="$(brew --prefix oh-my-posh 2>/dev/null)/themes/catppuccin.omp.json"
  if [[ -f "$OMP_CONFIG" ]]; then
    eval "$(oh-my-posh init zsh --config "$OMP_CONFIG")"
  fi
  unset OMP_CONFIG
fi
[[ -f "$HOME/workspace/catppuccin_mocha-zsh-syntax-highlighting.zsh" ]] && source "$HOME/workspace/catppuccin_mocha-zsh-syntax-highlighting.zsh"

#
# Startup Info
#
if [[ -z $FASTFETCH_SHOWN ]] && command -v fastfetch &>/dev/null && [[ -f "$HOME/workspace/fastfetch-config.jsonc" ]]; then
  fastfetch --config "$HOME/workspace/fastfetch-config.jsonc"
  export FASTFETCH_SHOWN=1
fi

# zprof